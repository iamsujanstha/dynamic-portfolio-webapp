rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.message is string && data.message.size() >= 10 && data.message.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // 1. Messages Collection
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      
      // No read/list/update/delete for the public
      // If the user wants to see their messages, we might need auth and check ownerId.
      // For now, it's a silent sink.
    }
  }
}
