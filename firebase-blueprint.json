{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "User contact messages sent via the contact form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email of the sender"
        },
        "message": {
          "type": "string",
          "description": "The message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages"
    }
  }
}
